# MCP Stack Environment Configuration
# Copy to .env and adjust values for your deployment.

# ── Deploy target ──────────────────────────────────────────────────
# Set SEARXNG_HOSTNAME to the hostname/IP that Copilot CLI will use
# to reach the MCP services. Examples:
#   Raspberry Pi:  raspberrypi  (or its IP)
#   Local/WSL:     localhost
SEARXNG_HOSTNAME=raspberrypi

# ── Ports ──────────────────────────────────────────────────────────
# SearXNG web UI / API port (also used by the local MCP bridge)
SEARXNG_PORT=8080

# Playwright MCP port (Copilot CLI connects here for browser automation)
PLAYWRIGHT_MCP_PORT=8931
